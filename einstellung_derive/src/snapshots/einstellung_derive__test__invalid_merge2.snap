/// --- input ---
#[derive(Config)]
struct ServerConfig {
    host: String,
    port: u16,
    #[config(merge = "subconfig")]
    is_active: bool,
}

/// --- output ---
::core::compile_error! {
    "Unknown value: `subconfig`. Available values: `append`, `function`, `replace`"
