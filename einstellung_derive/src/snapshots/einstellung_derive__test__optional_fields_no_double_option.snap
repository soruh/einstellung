/// --- input ---
#[derive(Config)]
struct ClientConfig {
    name: String,
    timeout_ms: Option<u32>,
    proxy: Option<String>,
}
/// --- output ---
#[derive(Default, Debug, ::einstellung::serde::Deserialize)]
#[serde(crate = "::einstellung::serde")]
struct ClientConfigPartial {
    name: Option<String>,
    timeout_ms: Option<u32>,
    proxy: Option<String>,
}
impl ::einstellung::PartialConfig for ClientConfigPartial {
    type Complete = ClientConfig;
    fn merge(self, next: Self) -> Self {
        Self {
            name: next.name.or(self.name),
            timeout_ms: next.timeout_ms.or(self.timeout_ms),
            proxy: next.proxy.or(self.proxy),
        }
    }
    fn build(self) -> Result<Self::Complete, ::einstellung::ConfigError> {
        let name = self.name.ok_or(::einstellung::ConfigError::MissingField("name"))?;
        let timeout_ms = self.timeout_ms;
        let proxy = self.proxy;
        Ok(ClientConfig {
            name,
            timeout_ms,
            proxy,
        })
    }
}
impl ::einstellung::Config for ClientConfig {
    type Partial = ClientConfigPartial;
}
