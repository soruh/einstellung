/// --- helper ---
pub fn merge_hosts(_: String, b: String) -> String {
    b
}

// ---------------------------------

/// --- input ---
#[derive(Config)]
struct ServerConfig {
    #[config(merge(function = "merge_hosts"))]
    host: String,
}

/// --- output ---
#[derive(Default, Debug, ::einstellung::serde::Deserialize)]
#[serde(crate = "::einstellung::serde")]
struct ServerConfigPartial {
    host: Option<String>,
}
impl ::einstellung::PartialConfig for ServerConfigPartial {
    type Complete = ServerConfig;
    fn merge(self, next: Self) -> Self {
        Self {
            host: merge_hosts(self.host, next.host),
        }
    }
    fn build(self) -> Result<Self::Complete, ::einstellung::ConfigError> {
        let host = self
            .host
            .ok_or(
                ::einstellung::ConfigError::MissingField(
                    ::einstellung::FieldPath::new("ServerConfig", "host"),
                ),
            )?;
        Ok(ServerConfig { host })
    }
}
impl ::einstellung::Config for ServerConfig {
    type Partial = ServerConfigPartial;
}
