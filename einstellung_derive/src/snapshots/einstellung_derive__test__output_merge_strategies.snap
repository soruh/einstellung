source: einstellung_derive/src/test.rs
expression: formatted
---
/// --- input ---
#[derive(Config)]
struct LoggerConfig {
    level: String,
    #[config(merge = "extend")]
    log_files: Vec<String>,
    #[config(merge = "replace")]
    output_format: String,
}

/// --- output ---
#[derive(Default, Debug, ::einstellung::serde::Deserialize)]
#[serde(crate = "::einstellung::serde")]
struct LoggerConfigPartial {
    level: Option<String>,
    #[serde(default)]
    log_files: Vec<String>,
    output_format: Option<String>,
}
impl ::einstellung::PartialConfig for LoggerConfigPartial {
    type Complete = LoggerConfig;
    fn merge(self, next: Self) -> Self {
        Self {
            level: next.level.or(self.level),
            log_files: {
                let mut log_files = self.log_files;
                log_files.extend(next.log_files);
                log_files
            },
            output_format: next.output_format.or(self.output_format),
        }
    }
    fn build(self) -> Result<Self::Complete, ::einstellung::ConfigError> {
        let level = self
            .level
            .ok_or(
                ::einstellung::ConfigError::MissingField(
                    ::einstellung::FieldPath::new("LoggerConfig", "level"),
                ),
            )?;
        let log_files = self.log_files;
        let output_format = self
            .output_format
            .ok_or(
                ::einstellung::ConfigError::MissingField(
                    ::einstellung::FieldPath::new("LoggerConfig", "output_format"),
                ),
            )?;
        Ok(LoggerConfig {
            level,
            log_files,
            output_format,
        })
    }
}
impl ::einstellung::Config for LoggerConfig {
    type Partial = LoggerConfigPartial;
}
