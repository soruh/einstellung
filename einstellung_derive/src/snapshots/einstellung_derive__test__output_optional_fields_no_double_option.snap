/// --- input ---
#[derive(Config)]
struct ClientConfig {
    name: String,
    timeout_ms: Option<u32>,
    proxy: Option<String>,
}

/// --- output ---
#[derive(::core::default::Default, ::einstellung::serde::Deserialize)]
#[serde(crate = "::einstellung::serde")]
struct ClientConfigPartial {
    name: Option<String>,
    timeout_ms: Option<u32>,
    proxy: Option<String>,
}
impl ::einstellung::PartialConfig for ClientConfigPartial {
    type Complete = ClientConfig;
    fn merge(
        self,
        next: Self,
    ) -> ::core::result::Result<Self, ::einstellung::ConfigError> {
        ::core::result::Result::Ok(Self {
            name: next.name.or(self.name),
            timeout_ms: next.timeout_ms.or(self.timeout_ms),
            proxy: next.proxy.or(self.proxy),
        })
    }
    fn build(
        self,
    ) -> ::core::result::Result<Self::Complete, ::einstellung::ConfigError> {
        let name = self
            .name
            .ok_or(
                ::einstellung::ConfigError::MissingField(
                    ::einstellung::FieldPath::new("ClientConfig", "name"),
                ),
            )?;
        let timeout_ms = self.timeout_ms;
        let proxy = self.proxy;
        ::core::result::Result::Ok(ClientConfig {
            name,
            timeout_ms,
            proxy,
        })
    }
}
impl ::einstellung::Config for ClientConfig {
    type Partial = ClientConfigPartial;
}
