/// --- input ---
#[derive(Config)]
struct ApiConfig {
    #[config(serde(rename = "API_KEY"))]
    key: String,
    #[config(serde(alias = "max_retries", default))]
    retries: u8,
    #[config(serde(skip_serializing_if = "Option::is_none"))]
    endpoint: Option<String>,
}

/// --- output ---
#[derive(Default, Debug, ::einstellung::serde::Deserialize)]
#[serde(crate = "::einstellung::serde")]
struct ApiConfigPartial {
    #[serde(rename = "API_KEY")]
    key: Option<String>,
    #[serde(alias = "max_retries", default)]
    retries: Option<u8>,
    #[serde(skip_serializing_if = "Option::is_none")]
    endpoint: Option<String>,
}
impl ::einstellung::PartialConfig for ApiConfigPartial {
    type Complete = ApiConfig;
    fn merge(self, next: Self) -> Self {
        Self {
            key: next.key.or(self.key),
            retries: next.retries.or(self.retries),
            endpoint: next.endpoint.or(self.endpoint),
        }
    }
    fn build(self) -> Result<Self::Complete, ::einstellung::ConfigError> {
        let key = self.key.ok_or(::einstellung::ConfigError::MissingField("key"))?;
        let retries = self
            .retries
            .ok_or(::einstellung::ConfigError::MissingField("retries"))?;
        let endpoint = self.endpoint;
        Ok(ApiConfig {
            key,
            retries,
            endpoint,
        })
    }
}
impl ::einstellung::Config for ApiConfig {
    type Partial = ApiConfigPartial;
}
