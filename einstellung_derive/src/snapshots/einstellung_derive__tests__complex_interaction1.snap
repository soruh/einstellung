struct AppConfig {
    #[config(rename = "db_config")]
    database: DatabaseConfig,
    #[config(default = 3000)]
    port: u16,
}
impl einstellung::Config for AppConfig {
    fn metadata() -> &'static einstellung::ConfigMetadata {}
    fn load(
        source: &dyn einstellung::ConfigSource,
    ) -> Result<Self, einstellung::ConfigError> {}
}
