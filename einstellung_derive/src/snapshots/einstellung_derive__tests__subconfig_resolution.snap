}
/// --- output ---
#[derive(Default, Debug, serde::Deserialize)]
pub struct RedisConfigPartial {
    pub cluster_mode: Option<bool>,
}
impl einstellung::PartialConfig for RedisConfigPartial {
    type Output = RedisConfig;
    fn merge(self, next: Self) -> Self {
        Self {
            cluster_mode: next.cluster_mode.or(self.cluster_mode),
        }
    }
    fn build(self) -> Result<Self::Output, einstellung::ConfigError> {
        let cluster_mode = self
            .cluster_mode
            .ok_or(einstellung::ConfigError::MissingField("cluster_mode"))?;
        Ok(RedisConfig { cluster_mode })
