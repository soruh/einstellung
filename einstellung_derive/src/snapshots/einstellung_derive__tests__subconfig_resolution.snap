/// --- input ---
#[derive(Config)]
struct DatabaseConfig {
    url: String,
    pool_size: u32,
}
/// --- output ---
#[derive(Default, Debug, serde::Deserialize)]
pub struct DatabaseConfigPartial {
    pub url: Option<String>,
    pub pool_size: Option<u32>,
}
impl einstellung::PartialConfig for DatabaseConfigPartial {
    type Output = DatabaseConfig;
    fn merge(self, next: Self) -> Self {
        Self {
            url: next.url.or(self.url),
            pool_size: next.pool_size.or(self.pool_size),
        }
    }
    fn build(self) -> Result<Self::Output, einstellung::ConfigError> {
        let url = self.url.ok_or(einstellung::ConfigError::MissingField("url"))?;
        let pool_size = self
            .pool_size
            .ok_or(einstellung::ConfigError::MissingField("pool_size"))?;
        Ok(DatabaseConfig { url, pool_size })
    }
}
impl einstellung::Config for DatabaseConfig {
    type Partial = DatabaseConfigPartial;
}

