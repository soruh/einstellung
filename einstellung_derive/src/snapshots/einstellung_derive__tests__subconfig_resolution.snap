/// --- input ---
#[derive(Config)]
struct AppConfig {
    app_name: String,
    #[config(subconfig)]
    database: DatabaseConfig,
    #[config(subconfig)]
    redis: RedisConfig,
}
/// --- output ---
#[derive(Default, Debug, serde::Deserialize)]
pub struct AppConfigPartial {
    pub app_name: Option<String>,
    pub database: Option<<DatabaseConfig as einstellung::Config>::Partial>,
    pub redis: Option<<RedisConfig as einstellung::Config>::Partial>,
}
impl einstellung::PartialConfig for AppConfigPartial {
    type Output = AppConfig;
    fn merge(self, next: Self) -> Self {
        Self {
            app_name: next.app_name.or(self.app_name),
            database: match (self.database, next.database) {
                (Some(a), Some(b)) => einstellung::PartialConfig::merge(a, b),
                (a, b) => a.or(b),
            },
            redis: match (self.redis, next.redis) {
                (Some(a), Some(b)) => einstellung::PartialConfig::merge(a, b),
                (a, b) => a.or(b),
            },
        }
    }
    fn build(self) -> Result<Self::Output, einstellung::ConfigError> {
        let app_name = self
            .app_name
            .ok_or(einstellung::ConfigError::MissingField("app_name"))?;
        let database = self.database.unwrap_or_default().build()?;
        let redis = self.redis.unwrap_or_default().build()?;
        Ok(AppConfig {
            app_name,
            database,
            redis,
        })
    }
}
impl einstellung::Config for AppConfig {
    type Partial = AppConfigPartial;
}

